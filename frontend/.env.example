# Copy this file to `.env` and fill in your deployed contract address.
# When VITE_CONTRACT_ADDRESS is unset the frontend runs in pure mock
# mode (no on-chain calls).

# Address of the deployed PredictionArena contract on GenLayer Studio.
# Each contract deployment represents ONE market — see contracts/DEPLOY.md.
# This is the live demo deployment; replace if you redeploy your own.
VITE_CONTRACT_ADDRESS=0x60Da1d81d4E7a7ED00D1AD3552688b42084c706e

# Which mock market id mirrors to the deployed contract. Default
# `bra-jam-20240605` matches the football smoke test in seed.md.
# Bets/resolves on this market id hit the on-chain contract; the other
# 8 markets in the demo stay in the local mock.
VITE_LIVE_MARKET_ID=bra-jam-20240605
