# Copy this file to `.env` and fill in your deployed contract address.
# When VITE_CONTRACT_ADDRESS is unset the frontend runs in pure mock
# mode (no on-chain calls).

# Address of the deployed PredictionArena multi-market contract on
# GenLayer Studio. Deploy contracts/PredictionArena.py (no constructor
# args), paste the address here, then click "⚡ Initialize On-Chain"
# in the Profile zone to seed all 9 demo markets in one tx.
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Optional: real Discord/X OAuth ──────────────────────────────────
# Without these, the Profile zone's Discord/X buttons stay as local
# demo toggles. Set them to enable real OAuth (popup → fetch profile).
#
# Discord:
#   1. https://discord.com/developers/applications → New Application
#   2. OAuth2 → Add redirect URI: http://localhost:5173/oauth/discord
#   3. Copy Application ID below
# VITE_DISCORD_CLIENT_ID=
#
# X (Twitter):
#   1. https://developer.x.com → create OAuth 2.0 app, type = Public client
#   2. Redirect URI: http://localhost:5173/oauth/x
#   3. Scopes: users.read, tweet.read
#   4. Copy Client ID below
# VITE_X_CLIENT_ID=
